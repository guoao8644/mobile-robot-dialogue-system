<mujoco model="g1_43dof scene">
  <include file="g1_29dof_with_hand.xml"/>

  <statistic center="0 0 0.5" extent="3.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20" offwidth="1024" offheight="1024"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="wall_mat"    rgba="0.6 0.55 0.45 0.4"/>
    <material name="box_red"     rgba="0.8 0.2 0.2 1"/>
    <material name="box_blue"    rgba="0.2 0.4 0.8 1"/>
    <material name="box_green"   rgba="0.2 0.7 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- ─── 長方形の範囲 (8m x 6m) ─────────────────────────
         中心 (0,0)、x方向 ±4m、y方向 ±3m
         壁の厚さ 0.1m、高さ 1.2m
    ──────────────────────────────────────────────────── -->
    <!-- 奥の壁 (+x) -->
    <geom name="wall_xp" type="box" size="0.05 3.0 0.6"
          pos="4.0 0 0.6" material="wall_mat" contype="1" conaffinity="1"/>
    <!-- 手前の壁 (-x) -->
    <geom name="wall_xn" type="box" size="0.05 3.0 0.6"
          pos="-4.0 0 0.6" material="wall_mat" contype="1" conaffinity="1"/>
    <!-- 右の壁 (+y) -->
    <geom name="wall_yp" type="box" size="4.0 0.05 0.6"
          pos="0 3.0 0.6" material="wall_mat" contype="1" conaffinity="1"/>
    <!-- 左の壁 (-y) -->
    <geom name="wall_yn" type="box" size="4.0 0.05 0.6"
          pos="0 -3.0 0.6" material="wall_mat" contype="1" conaffinity="1"/>

    <!-- ─── 障害物ボックス ─────────────────────────────────
         ロボットは原点付近からスタートするので少し離して配置
    ──────────────────────────────────────────────────── -->
    <!-- 赤い箱 (0.4m x 0.4m x 0.5m) -->
    <geom name="box_red" type="box" size="0.2 0.2 0.25"
          pos="2.0 1.0 0.25" material="box_red" contype="1" conaffinity="1"/>
    <!-- 青い箱 (0.3m x 0.6m x 0.4m) -->
    <geom name="box_blue" type="box" size="0.15 0.3 0.2"
          pos="-1.5 -1.5 0.2" material="box_blue" contype="1" conaffinity="1"/>
    <!-- 緑の箱 (0.5m x 0.5m x 0.3m) -->
    <geom name="box_green" type="box" size="0.25 0.25 0.15"
          pos="1.0 -2.0 0.15" material="box_green" contype="1" conaffinity="1"/>

    <!-- ─── カメラ ────────────────────────────────────────
         Tab キーで切り替え可能（MuJoCo ビューア標準機能）
         マウスで視点操作も可能
    ──────────────────────────────────────────────────── -->
    <!-- 固定俯瞰カメラ：空間全体を斜め上から見る -->
    <camera name="overview"
            pos="-5.0 -4.0 4.0"
            xyaxes="0.7 -0.7 0  0.4 0.4 0.82"/>

    <!-- 固定正面カメラ：ロボット正面から水平に見る -->
    <camera name="front"
            pos="-3.5 0 1.2"
            xyaxes="0 -1 0  0 0 1"/>

    <!-- ─── その他 ─────────────────────────────────────── -->
    <site name="com_marker" pos="0.1 0 0" size="0.05" rgba="1 0 0 1" type="sphere"/>
  <body name="user" mocap="true" pos="1.5 0 0.9" quat="0 0 0 1">
    <geom type="sphere" size="0.12" pos="0 0 0.1" rgba="0.8 0.6 0.4 1" contype="0" conaffinity="0"/>
    <geom type="capsule" fromto="0 0 -0.05 0 0 -0.35" size="0.08" rgba="0.4 0.6 0.9 1" contype="0" conaffinity="0"/>
    <geom type="capsule" fromto="0 0.08 -0.05 0 0.1 -0.4" size="0.04" rgba="0.8 0.6 0.4 1" contype="0" conaffinity="0"/>
    <geom type="capsule" fromto="0 -0.08 -0.05 0 -0.1 -0.4" size="0.04" rgba="0.8 0.6 0.4 1" contype="0" conaffinity="0"/>
    <geom type="capsule" fromto="0 0.06 -0.35 0 0.07 -0.75" size="0.05" rgba="0.4 0.6 0.9 1" contype="0" conaffinity="0"/>
    <geom type="capsule" fromto="0 -0.06 -0.35 0 -0.07 -0.75" size="0.05" rgba="0.4 0.6 0.9 1" contype="0" conaffinity="0"/>
    <camera name="user_eye" pos="0.1 0 0.1" xyaxes="0 -1 0 0 0 1" fovy="70"/>
  </body>

  </worldbody>

  <default>
    <geom friction="1.0"/>
  </default>
</mujoco>
